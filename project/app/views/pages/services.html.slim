css:
  @keyframes pulse-subtle {
    0%, 100% {
      box-shadow: 0 0 0 0 rgba(37, 211, 102, 0.4);
    }
    50% {
      box-shadow: 0 0 0 8px rgba(37, 211, 102, 0);
    }
  }

  .animate-pulse-subtle {
    animation: pulse-subtle 2s infinite;
  }

  #serviceModal.show {
    opacity: 1;
  }

  #serviceModal.show #modalContainer {
    opacity: 1;
    transform: scale(1);
  }

