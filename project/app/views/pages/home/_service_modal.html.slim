- wa = { generalPest: whatsapp_link(:general_pest), termite: whatsapp_link(:termite), bedBug: whatsapp_link(:bed_bug), rodent: whatsapp_link(:rodent), outdoor: whatsapp_link(:outdoor), restaurant: whatsapp_link(:restaurant), hotel: whatsapp_link(:hotel), commercial: whatsapp_link(:commercial), fumigation: whatsapp_link(:fumigation), preConstruction: whatsapp_link(:pre_construction), preventive: whatsapp_link(:preventive) }

div id="serviceModal" onclick="if(event.target === this) closeModal()" class="fixed inset-0 bg-black bg-opacity-50 hidden z-50 flex items-center justify-center p-4 transition-opacity duration-300"
  div class="bg-white rounded-2xl max-w-2xl w-full max-h-[90vh] overflow-y-auto shadow-2xl transform transition-all duration-300"
    div class="sticky top-0 bg-gradient-to-r from-[#0F4D23] to-[#1E7A3A] text-white p-6 rounded-t-2xl"
      div class="flex items-start justify-between"
        h3 id="modalTitle" class="text-2xl font-bold leading-tight pr-4"
        button onclick="closeModal()" class="text-white hover:text-[#CFE8B3] transition cursor-pointer flex-shrink-0"
          svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"
            path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"

    div class="p-8"
      div id="modalIntro" class="text-[#1E7A3A] text-lg leading-relaxed mb-8"

      div class="mb-8"
        h4 class="text-xl font-bold text-[#0F4D23] mb-4 flex items-center gap-2"
          svg class="w-6 h-6 text-[#1E7A3A]" fill="none" stroke="currentColor" viewBox="0 0 24 24"
            path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"
