javascript:
  const waUrls = {
    generalPest:     "#{wa[:generalPest]}",
    termite:         "#{wa[:termite]}",
    bedBug:          "#{wa[:bedBug]}",
    rodent:          "#{wa[:rodent]}",
    outdoor:         "#{wa[:outdoor]}",
    restaurant:      "#{wa[:restaurant]}",
    hotel:           "#{wa[:hotel]}",
    commercial:      "#{wa[:commercial]}",
    fumigation:      "#{wa[:fumigation]}",
    preConstruction: "#{wa[:preConstruction]}",
    preventive:      "#{wa[:preventive]}"
  };

  const serviceData = {
    generalPest:     { title: "General Pest Control",       intro: "Comprehensive protection for your home against common household pests. Our treatments ensure year-round peace of mind.",                                               details: ["Coverage for ants, cockroaches, spiders, silverfish, and more", "Quarterly treatment plans available", "Interior and exterior barrier protection", "Eco-friendly treatment options", "Thorough inspection of problem areas"],    special: ["100% satisfaction guarantee or we re-treat at no cost", "Safe for children and pets", "Same-day emergency service available"] },
    termite:         { title: "Termite Control",            intro: "Protect your biggest investment from devastating termite damage with our comprehensive inspection and treatment program.",                                               details: ["Free professional termite inspection", "Advanced liquid termiticide treatments", "Termite baiting and monitoring systems", "Wood treatment consultation", "Annual inspections for continued protection"],                      special: ["Early detection saves thousands in repair costs", "Certified termite specialists"] },
    bedBug:          { title: "Bed Bug Treatment",          intro: "Fast, effective elimination of bed bug infestations. We understand the urgency and handle every case with discretion.",                                                 details: ["Heat treatments that kill all life stages instantly", "Steam treatment options available", "Comprehensive inspection to determine infestation extent", "Customized treatment plan based on severity"],                      special: ["Same-day emergency service available", "Discreet service", "Treatment effectiveness guaranteed", "Follow-up inspections included"] },
    rodent:          { title: "Rodent Control",             intro: "Complete rodent elimination and prevention. We identify and seal entry points to prevent future infestations.",                                                         details: ["Thorough property inspection", "Entry point identification and exclusion", "Strategic trap placement", "Tamper-resistant bait stations", "Sanitation advice included"],                                                    special: ["Humane and effective methods", "Safe for families and pets", "Follow-up visits included", "Guaranteed results"] },
    outdoor:         { title: "Outdoor Pest Control",       intro: "Reclaim your outdoor spaces from mosquitoes, ticks, and other pests. Perfect for families who want to enjoy their yard safely.",                                       details: ["Mosquito barrier spray treatments", "Tick and flea control for entire yard", "Lawn pest control", "Fire ant mound treatments", "Garden pest control"],                                                                    special: ["Reduces mosquito population by up to 90%", "Protection lasts 3-4 weeks per treatment", "Safe for children and pets once dry", "Natural options available"] },
    restaurant:      { title: "Restaurant & Food Service",  intro: "Specialized pest management for food service establishments. We help you maintain compliance and protect your reputation.",                                             details: ["Monthly preventive service visits", "Detailed inspection and documentation reports", "Rodent monitoring stations", "Professional fly control systems"],                                                                    special: ["Complete documentation for health inspections", "Food-safe approved treatments only", "24/7 emergency service", "Discreet off-hours service"] },
    hotel:           { title: "Hotels & Hospitality",       intro: "Discreet, professional pest management designed for the hospitality industry. We protect your guests and your reputation.",                                             details: ["Service in unmarked vehicles", "Flexible scheduling including overnight", "Bed bug prevention and treatment", "Regular guest room inspections", "Common area and kitchen treatments"],                                      special: ["Proactive monitoring to prevent issues", "Rapid response to guest complaints", "Reputation protection is our priority"] },
    commercial:      { title: "Commercial Buildings",       intro: "Professional pest management for offices, retail, warehouses, and healthcare facilities with minimal disruption.",                                                     details: ["Quarterly or monthly service options", "After-hours treatments available", "Low-odor non-disruptive methods", "Comprehensive service documentation", "Eco-friendly options"],                                              special: ["Minimal disruption to operations", "Regulatory compliance support", "Emergency service available", "Customized programs"] },
    fumigation:      { title: "Fumigation Services",        intro: "Complete structure fumigation for severe infestations requiring whole-building treatment by licensed professionals.",                                                   details: ["Whole-structure fumigation", "Severe infestation elimination", "Complete pest eradication guarantee", "Professional tenting and sealing"],                                                                                special: ["Licensed and certified specialists", "Strict safety protocols", "Air quality testing before re-entry", "Official clearance certificate"] },
    preConstruction: { title: "Pre-Construction Treatment", intro: "The most effective termite protection starts before construction. Long-lasting protection for your new building.",                                                     details: ["Soil termiticide application", "Foundation and slab treatments", "Under-slab protection", "Plumbing penetration treatments", "Post-construction perimeter barriers"],                                                      special: ["More cost-effective than post-construction treatment", "Official treatment certification", "Coordination with builders"] },
    preventive:      { title: "Preventive Maintenance",     intro: "Prevention is always better than treatment. Our program stops pest problems before they start.",                                                                       details: ["Quarterly property inspections", "Exterior perimeter barrier treatments", "Entry point identification", "Moisture problem advice", "Seasonal prevention strategies"],                                                      special: ["Early detection of potential problems", "Lower costs than reactive treatment", "Year-round peace of mind", "Priority emergency service for members"] }
  };

  function openModal(serviceKey) {
    const service = serviceData[serviceKey];
    if (!service) return;
    document.getElementById('modalTitle').textContent = service.title;
    document.getElementById('modalIntro').textContent = service.intro;
    document.getElementById('modalDetails').innerHTML = service.details.map(item => `<div class="flex items-start gap-3"><svg class="w-5 h-5 text-[#1E7A3A] flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg><span class="text-[#1E7A3A]">${item}</span></div>`).join('');
    document.getElementById('modalSpecial').innerHTML = service.special.map(item => `<div class="flex items-start gap-3"><svg class="w-5 h-5 text-[#1E7A3A] flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg><span class="text-[#0F4D23] font-medium">${item}</span></div>`).join('');
    document.getElementById('modalWhatsApp').href = waUrls[serviceKey];
    document.getElementById('serviceModal').classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    document.getElementById('serviceModal').classList.add('hidden');
    document.body.style.overflow = 'auto';
  }

  document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeModal(); });
