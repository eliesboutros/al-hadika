      // ========== GLOBAL EVENT LISTENERS (FIXED) ==========
      
      // Function to attach modal event listeners (can be called multiple times safely)
      function ensureModalListeners() {
        // Home page service modal - click outside to close
        const serviceModal = document.getElementById('serviceModal');
        if (serviceModal && !serviceModal.dataset.listenerAttached) {
          serviceModal.dataset.listenerAttached = 'true';
          serviceModal.addEventListener('click', function(e) {
            // Only close if clicking the backdrop (not the modal content)
            if (e.target === serviceModal) {
              closeModal();
            }
          });
        }

        // Footer modal - click outside to close
        const footerModal = document.getElementById('footerServiceModal');
        if (footerModal && !footerModal.dataset.listenerAttached) {
          footerModal.dataset.listenerAttached = 'true';
          footerModal.addEventListener('click', function(e) {
            // Only close if clicking the backdrop (not the modal content)
            if (e.target === footerModal) {
              closeFooterModal();
            }
          });
        }
      }

      // Attach listeners on turbo:load (for Turbo/Rails)
      document.addEventListener('turbo:load', function() {
        ensureModalListeners();
      });

      // Attach listeners on DOMContentLoaded (fallback for non-Turbo pages)
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function() {
          ensureModalListeners();
        });
      } else {
        // DOM already loaded, attach immediately
        ensureModalListeners();
      }

      // Escape key to close modals (global, always active)
      document.addEventListener('keydown', function(event) {
        if (event.key === 'Escape' || event.key === 'Esc') {
          const serviceModal = document.getElementById('serviceModal');
          const footerModal = document.getElementById('footerServiceModal');
          
          if (serviceModal && !serviceModal.classList.contains('hidden')) {
            closeModal();
          }
          if (footerModal && !footerModal.classList.contains('hidden')) {
