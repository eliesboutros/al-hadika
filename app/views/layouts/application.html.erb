            "Entry point identification and sealing",
            "Strategic trap placement",
            "Tamper-resistant rodent bait stations",
            "Sanitation and cleanup services"
          ],
          special: [
            "Humane and effective methods",
            "Safe for family and pets",
            "Regular follow-up visits included",
            "Attic and crawl space treatments"
          ],
          whatsappMessage: "Hello! I would like to inquire about your Rodent Control services. Could you please provide me with more information?"
        }
      };

      function openFooterModal(serviceKey) {
        const service = footerServiceData[serviceKey];
        if (!service) return;

        document.getElementById('footerModalTitle').textContent = service.title;
        
        let contentHTML = `<p class="text-lg leading-relaxed mb-4">${service.description}</p>`;
        
        if (service.details && service.details.length > 0) {
          contentHTML += '<div class="mt-6"><h4 class="text-lg font-bold text-[#0F4D23] mb-3">What We Offer:</h4><ul class="space-y-2">';
          service.details.forEach(item => {
            contentHTML += `<li class="flex items-start"><svg class="w-5 h-5 text-[#1E7A3A] mr-2 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg><span>${item}</span></li>`;
          });
          contentHTML += '</ul></div>';
        }
        
        document.getElementById('footerModalContent').innerHTML = contentHTML;
        
        let specialHTML = '';
        if (service.special && service.special.length > 0) {
          service.special.forEach(item => {
            specialHTML += `<div class="flex items-start"><svg class="w-5 h-5 text-[#1E7A3A] mr-2 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg><span class="text-[#0F4D23]">${item}</span></div>`;
          });
        }
        document.getElementById('footerModalSpecial').innerHTML = specialHTML;
        
        const whatsappLink = `https://wa.me/96179365375?text=${encodeURIComponent(service.whatsappMessage)}`;
        document.getElementById('footerModalWhatsApp').href = whatsappLink;
        
        document.getElementById('footerServiceModal').classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      }

      function closeFooterModal() {
        document.getElementById('footerServiceModal').classList.add('hidden');
        document.body.style.overflow = 'auto';
      }

      // Close modal when clicking outside
      document.getElementById('footerServiceModal').addEventListener('click', function(e) {
        if (e.target === this) {
          closeFooterModal();
        }
      });
      
      // Close with Escape key
      document.addEventListener('keydown', function(event) {
        if (event.key === 'Escape') {
          const modal = document.getElementById('footerServiceModal');
          if (modal && !modal.classList.contains('hidden')) {
            closeFooterModal();
          }
        }
      });
    </script>

    <!-- Mobile menu toggle script -->
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        const button = document.getElementById('mobile-menu-button');
        const menu = document.getElementById('mobile-menu');
        
        if (button && menu) {
          button.addEventListener('click', function() {
            menu.classList.toggle('hidden');
          });
        }
      });
    </script>
  </body>
</html>