          <%= link_to "About", about_path, class: "text-[#0F4D23] hover:bg-[#CFE8B3] hover:text-[#1E7A3A] block px-4 py-3 rounded-lg text-base font-medium transition text-center #{current_page?(about_path) ? 'bg-[#9BBF78] text-white shadow-md' : ''}" %>
