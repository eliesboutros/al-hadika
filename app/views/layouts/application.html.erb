          <%= link_to "About", about_path, class: "text-[#0F4D23] hover:bg-[#CFE8B3] hover:text-[#1E7A3A] block px-4 py-3 rounded-lg text-base font-medium transition text-center #{current_page?(about_path) ? 'bg-[#9BBF78] text-white shadow-md' : ''}" %>
          <%= link_to "Reviews", reviews_path, class: "text-[#0F4D23] hover:bg-[#CFE8B3] hover:text-[#1E7A3A] block px-4 py-3 rounded-lg text-base font-medium transition text-center #{current_page?(reviews_path) ? 'bg-[#9BBF78] text-white shadow-md' : ''}" %>
          <%= link_to "Contact", contact_path, class: "text-[#0F4D23] hover:bg-[#CFE8B3] hover:text-[#1E7A3A] block px-4 py-3 rounded-lg text-base font-medium transition text-center #{current_page?(contact_path) ? 'bg-[#9BBF78] text-white shadow-md' : ''}" %>
          <%= link_to "https://wa.me/96179365375?text=Hello%2C%20I%20would%20like%20a%20free%20inspection", target: "_blank", class: "bg-[#0F4D23] text-white block mx-0 mt-3 px-4 py-3 rounded-lg text-base font-semibold text-center hover:bg-[#1E7A3A] transition" do %>
            WhatsApp Us Now
          <% end %>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="min-h-screen">
