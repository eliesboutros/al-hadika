              <span class="font-medium group-hover:font-semibold">Call Us</span>
            </a>
            <a href="mailto:Al-Hadika@outlook.com" class="flex items-center gap-2 hover:text-[#9BBF78] transition-all duration-300 hover:scale-105 group">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
