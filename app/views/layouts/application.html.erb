              <span class="relative font-bold text-white px-4 py-1 bg-gradient-to-r from-red-700 via-red-600 to-red-700 rounded-full border-2 border-red-400 shadow-lg shadow-red-500/50 flex items-center gap-2 hover:scale-105 transition-all duration-300" style="text-shadow: 0 0 10px rgba(239, 68, 68, 0.8);">
                <svg class="w-4 h-4 text-red-200 animate-pulse" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
