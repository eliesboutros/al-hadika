            </div>
          </div>

          <!-- CTA Button - Desktop -->
          <div class="hidden lg:block">
            <%= link_to "https://wa.me/96179365375?text=Hello%2C%20I%20would%20like%20a%20free%20inspection", target: "_blank", class: "bg-[#1E7A3A] text-white px-6 py-3 rounded-lg font-semibold hover:bg-[#0F4D23] transition duration-200 shadow-lg hover:shadow-xl" do %>
