              <li><a href="#" onclick="openFooterModal('bedBug'); return false;" class="text-[#CFE8B3] hover:text-white hover:underline transition duration-200 cursor-pointer">Bed Bug Treatment</a></li>
              <li><a href="#" onclick="openFooterModal('restaurant'); return false;" class="text-[#CFE8B3] hover:text-white hover:underline transition duration-200 cursor-pointer">Restaurant Services</a></li>
              <li><a href="#" onclick="openFooterModal('rodent'); return false;" class="text-[#CFE8B3] hover:text-white hover:underline transition duration-200 cursor-pointer">Rodent Control</a></li>
            </ul>
          </div>

          <!-- Contact -->
          <div class="text-center sm:text-left">
            <h4 class="text-xl font-semibold mb-6 text-[#9BBF78]">Contact Us</h4>
            <ul class="space-y-3 text-base">
              <li><a href="tel:+96179365375" class="text-[#CFE8B3] hover:text-white transition flex items-center justify-center sm:justify-start gap-2">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
                </svg>
