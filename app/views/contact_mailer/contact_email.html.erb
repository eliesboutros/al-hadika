<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    body {
      font-family: Arial, sans-serif;
      line-height: 1.6;
      color: #333;
      max-width: 600px;
      margin: 0 auto;
      padding: 20px;
    }
    .header {
      background: linear-gradient(to right, #0F4D23, #1E7A3A);
      color: white;
      padding: 20px;
      text-align: center;
      border-radius: 8px 8px 0 0;
    }
    .content {
      background: #f5f5f5;
      padding: 20px;
      border-left: 4px solid #0F4D23;
    }
    .field {
      margin-bottom: 15px;
      background: white;
      padding: 12px;
      border-radius: 4px;
    }
    .label {
      font-weight: bold;
      color: #0F4D23;
      display: block;
      margin-bottom: 5px;
    }
    .value {
      color: #1E7A3A;
    }
    .message-box {
      background: white;
      padding: 15px;
      border-radius: 4px;
      border-left: 3px solid #9BBF78;
      margin-top: 15px;
    }
    .footer {
      text-align: center;
      margin-top: 20px;
      padding: 15px;
      background: #F5EED3;
      border-radius: 0 0 8px 8px;
      font-size: 12px;
      color: #666;
    }
  </style>
</head>
<body>
  <div class="header">
    <h1 style="margin: 0;">🌿 Al-Hadika - New Contact Form Submission</h1>
  </div>
  
  <div class="content">
    <div class="field">
      <span class="label">Name:</span>
      <span class="value"><%= @first_name %> <%= @last_name %></span>
    </div>
    
    <div class="field">
      <span class="label">Email:</span>
      <span class="value"><%= @email %></span>
    </div>
    
    <div class="field">
      <span class="label">Phone:</span>
      <span class="value"><%= @phone %></span>
    </div>
    
    <div class="field">
      <span class="label">Service Interested In:</span>
      <span class="value"><%= @service %></span>
    </div>
    
    <div class="message-box">
      <span class="label">Message:</span>
      <p class="value"><%= simple_format(@message) %></p>
    </div>
  </div>
  
  <div class="footer">
    <p><strong>Al-Hadika Pest Control & Garden Services</strong></p>
    <p>Sea Side Road, Batroun, Lebanon</p>
    <p>📞 +961 79 365 375 | 📧 Al-Hadika@outlook.com</p>
    <p style="margin-top: 10px; font-style: italic;">We eliminate what bugs you.</p>
  </div>
</body>
</html>