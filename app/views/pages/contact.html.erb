<script>
// FAQ Toggle Function
function toggleFAQ(button) {
  const answer = button.nextElementSibling;
  const icon = button.querySelector('svg');
  
  // Toggle answer visibility
  answer.classList.toggle('hidden');
  
  // Rotate icon
  icon.classList.toggle('rotate-180');
}

// Open/Closed Status Function
function updateBusinessStatus() {
  const statusBadge = document.getElementById('statusBadge');
  
  // Get Lebanon time (UTC+2)
  const now = new Date();
  const lebanonTime = new Date(now.toLocaleString('en-US', { timeZone: 'Asia/Beirut' }));
  
  const day = lebanonTime.getDay(); // 0 = Sunday, 1 = Monday, etc.
  const hours = lebanonTime.getHours();
  const minutes = lebanonTime.getMinutes();
  
  let isOpen = false;
  let message = '';
  let nextOpenTime = '';
  
  // Sunday = Closed
  if (day === 0) {
    isOpen = false;
    message = '🔴 CLOSED NOW';
    nextOpenTime = 'Opens Monday at 8:00 AM';
  }
  // Monday - Friday: 8 AM - 11 PM
  else if (day >= 1 && day <= 5) {
    if (hours >= 8 && hours < 23) {
      isOpen = true;
      message = '🟢 OPEN NOW';
      nextOpenTime = 'Closes at 11:00 PM';
    } else {
      isOpen = false;
      message = '🔴 CLOSED NOW';
      if (hours < 8) {
        nextOpenTime = 'Opens today at 8:00 AM';
      } else {
        nextOpenTime = day === 5 ? 'Opens Saturday at 9:00 AM' : 'Opens tomorrow at 8:00 AM';
      }
    }
  }
  // Saturday: 9 AM - 10 PM
  else if (day === 6) {
    if (hours >= 9 && hours < 22) {
      isOpen = true;
      message = '🟢 OPEN NOW';
      nextOpenTime = 'Closes at 10:00 PM';
    } else {
      isOpen = false;
      message = '🔴 CLOSED NOW';
      if (hours < 9) {
        nextOpenTime = 'Opens today at 9:00 AM';
      } else {
        nextOpenTime = 'Opens Monday at 8:00 AM';
      }
    }
  }
  
  // Update the badge
  if (isOpen) {
    statusBadge.className = 'mb-6 p-4 rounded-lg text-center font-bold text-lg bg-green-100 border-2 border-green-500 text-green-700';
    statusBadge.innerHTML = `
      <div>${message}</div>
      <div class="text-sm font-normal mt-1">${nextOpenTime}</div>
    `;
  } else {
    statusBadge.className = 'mb-6 p-4 rounded-lg text-center font-bold text-lg bg-red-100 border-2 border-red-500 text-red-700';
    statusBadge.innerHTML = `
      <div>${message}</div>
      <div class="text-sm font-normal mt-1">${nextOpenTime}</div>
    `;
  }
}

// Update status on page load
document.addEventListener('DOMContentLoaded', function() {
  updateBusinessStatus();
  // Update every minute
  setInterval(updateBusinessStatus, 60000);
});
</script>