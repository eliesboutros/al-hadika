<!-- Hero Section -->
<div class="bg-gradient-to-r from-[#0F4D23] to-[#1E7A3A] text-white py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h1 class="text-4xl lg:text-5xl font-bold mb-4">Contact Us</h1>
    <p class="text-xl text-[#CFE8B3]">We're here to help! Get in touch with us today</p>
  </div>
</div>

<!-- Contact Information Section -->
<div class="py-16 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      
      <!-- Contact Form -->
      <div class="bg-white rounded-2xl shadow-xl border border-[#CFE8B3] p-8 lg:p-10">
        <h2 class="text-3xl font-bold text-[#0F4D23] mb-6">Send Us a Message</h2>
        <p class="text-[#1E7A3A] mb-8">Fill out the form below and we'll get back to you within 24 hours.</p>
        
        <%= form_with url: contact_path, method: :post, local: true, class: "space-y-6", id: "contactForm" do |f| %>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-[#0F4D23] font-semibold mb-2">First Name *</label>
              <%= f.text_field :first_name, required: true, class: "w-full border border-[#CFE8B3] rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-[#1E7A3A] transition", placeholder: "John" %>
            </div>
            <div>
              <label class="block text-[#0F4D23] font-semibold mb-2">Last Name *</label>
              <%= f.text_field :last_name, required: true, class: "w-full border border-[#CFE8B3] rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-[#1E7A3A] transition", placeholder: "Doe" %>
            </div>
          </div>

          <div>
            <label class="block text-[#0F4D23] font-semibold mb-2">Email Address *</label>
            <%= f.email_field :email, required: true, class: "w-full border border-[#CFE8B3] rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-[#1E7A3A] transition", placeholder: "john.doe@example.com" %>
          </div>

          <div>
            <label class="block text-[#0F4D23] font-semibold mb-2">Phone Number *</label>
            <%= f.telephone_field :phone, required: true, class: "w-full border border-[#CFE8B3] rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-[#1E7A3A] transition", placeholder: "+961 79 123 456" %>
          </div>

          <div>
            <label class="block text-[#0F4D23] font-semibold mb-2">Service Interested In</label>
            <%= f.select :service, 
              options_for_select([
                "Select a service",
                "General Pest Control",
                "Termite Treatment",
                "Bed Bug Treatment",
                "Rodent Control",
                "Outdoor Pest Control",
                "Restaurant Services",
                "Hotel Services",
                "Commercial Services",
                "Other"
              ]), 
              {}, 
              class: "w-full border border-[#CFE8B3] rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-[#1E7A3A] cursor-pointer transition" 
            %>
          </div>

          <div>
            <label class="block text-[#0F4D23] font-semibold mb-2">Message *</label>
            <%= f.text_area :message, rows: 5, required: true, class: "w-full border border-[#CFE8B3] rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-[#1E7A3A] transition", placeholder: "Tell us about your pest control needs..." %>
          </div>

          <%= f.submit "Send Message", class: "w-full bg-gradient-to-r from-[#0F4D23] to-[#1E7A3A] text-white px-8 py-4 rounded-lg font-bold hover:shadow-lg hover:scale-105 transition-all duration-200 cursor-pointer" %>
        <% end %>

        <!-- Success/Error Messages -->
        <% if flash[:notice] %>
          <div class="mt-4 bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-lg">
            <%= flash[:notice] %>
          </div>
        <% end %>
        <% if flash[:alert] %>
          <div class="mt-4 bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg">
            <%= flash[:alert] %>
          </div>
        <% end %>
      </div>

      <!-- Contact Information -->
      <div class="space-y-8">
        <!-- Office Hours with Live Status -->
        <div class="bg-[#F5EED3] rounded-2xl p-8">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-14 h-14 bg-gradient-to-r from-[#0F4D23] to-[#1E7A3A] rounded-full flex items-center justify-center">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <h3 class="text-2xl font-bold text-[#0F4D23]">Office Hours</h3>
          </div>

