<!-- FAQ Section -->
<div class="py-16 bg-[#F5EED3]">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-[#0F4D23] mb-4">Frequently Asked Questions</h2>
      <p class="text-[#1E7A3A]">Quick answers to common questions</p>
    </div>

    <div class="space-y-4">
      
      <div class="bg-white rounded-lg shadow-md border border-[#CFE8B3] overflow-hidden">
        <button class="faq-question w-full text-left p-6 flex items-center justify-between hover:bg-[#F5EED3] transition cursor-pointer" onclick="toggleFAQ(this)">
          <span class="font-bold text-[#0F4D23] text-lg">How quickly can you respond to an emergency?</span>
          <svg class="w-6 h-6 text-[#1E7A3A] transform transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
