    });
    document.getElementById('modalDetails').innerHTML = detailsHTML;
    
    // Set special features
    let specialHTML = '';
    service.special.forEach(item => {
      specialHTML += `
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-[#1E7A3A] flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
          <span class="text-[#0F4D23] font-medium">${item}</span>
        </div>
      `;
    });
    document.getElementById('modalSpecial').innerHTML = specialHTML;
    
    const whatsappLink = `https://wa.me/96179365375?text=${encodeURIComponent(service.whatsappMessage)}`;
    document.getElementById('modalWhatsApp').href = whatsappLink;
    
    document.getElementById('serviceModal').classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    document.getElementById('serviceModal').classList.add('hidden');
    document.body.style.overflow = 'auto';
  }

  // Close modal when clicking outside
  document.getElementById('serviceModal').addEventListener('click', function(e) {
    if (e.target === this) {
      closeModal();
    }
  });

  // Close modal with Escape key
  document.addEventListener('keydown', function(event) {
    if (event.key === 'Escape') {
      const modal = document.getElementById('serviceModal');
      if (!modal.classList.contains('hidden')) {
        closeModal();
      }
    }
  });
</script>

