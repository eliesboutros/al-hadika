// Track clicks for analytics
function trackServiceClick(serviceName) {
  // You can implement actual analytics here (Google Analytics, etc.)
  console.log(`Service clicked: ${serviceName} at ${new Date().toISOString()}`);
  
  // Example: Send to analytics
  if (typeof gtag !== 'undefined') {
    gtag('event', 'service_modal_open', {
      'service_name': serviceName
    });
  }
}

function openModal(serviceKey) {
  const service = serviceData[serviceKey];
  if (!service) return;
  
  // Track the click
  trackServiceClick(service.title);
  
  const modal = document.getElementById('serviceModal');
  const container = document.getElementById('modalContainer');
  
  // Set title
  document.getElementById('modalTitle').textContent = service.title;
  
  // Set intro
  document.getElementById('modalIntro').textContent = service.intro;
  
  // Set details
  let detailsHTML = '';
  service.details.forEach(item => {
    detailsHTML += `
      <div class="flex items-start gap-3">
        <svg class="w-5 h-5 text-[#1E7A3A] flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
        </svg>
        <span class="text-[#1E7A3A]">${item}</span>
      </div>
    `;
  });
  document.getElementById('modalDetails').innerHTML = detailsHTML;
  
  // Set special features
  let specialHTML = '';
  service.special.forEach(item => {
    specialHTML += `
      <div class="flex items-start gap-3">
        <svg class="w-5 h-5 text-[#1E7A3A] flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
        </svg>
        <span class="text-[#0F4D23] font-medium">${item}</span>
      </div>
    `;
  });
  document.getElementById('modalSpecial').innerHTML = specialHTML;
  
  // Set WhatsApp link with dynamic message
  const whatsappLink = `https://wa.me/96179365375?text=${encodeURIComponent(service.whatsappMessage)}`;
  document.getElementById('modalWhatsApp').href = whatsappLink;
  
  // Show modal with animation
  modal.classList.remove('hidden');
  setTimeout(() => {
    modal.classList.add('show');
  }, 10);
  
  document.body.style.overflow = 'hidden';
}

function closeModal() {
  const modal = document.getElementById('serviceModal');
  modal.classList.remove('show');
  
  setTimeout(() => {
    modal.classList.add('hidden');
    document.body.style.overflow = 'auto';
  }, 300);
}

// Close modal when clicking outside
document.getElementById('serviceModal').addEventListener('click', function(e) {
  if (e.target === this) {
    closeModal();
  }
});

// Close modal with Escape key
document.addEventListener('keydown', function(event) {
  if (event.key === 'Escape') {
    const modal = document.getElementById('serviceModal');
    if (!modal.classList.contains('hidden')) {
      closeModal();
    }
  }
});
</script>